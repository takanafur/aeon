{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "heartbeat"
      },
      "children": [
        "alert",
        "sep1",
        "facts",
        "sep2",
        "investigation"
      ]
    },
    "alert": {
      "type": "Alert",
      "props": {
        "type": "warning",
        "message": "Missed two scheduled runs today (08:00 and 14:00 UTC)"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "facts": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "fact1",
        "fact2",
        "fact3",
        "fact4"
      ]
    },
    "fact1": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "sm"
      },
      "children": [
        "label1",
        "value1"
      ]
    },
    "label1": {
      "type": "Text",
      "props": {
        "text": "Last success:",
        "variant": "body"
      }
    },
    "value1": {
      "type": "Text",
      "props": {
        "text": "2026-05-18 20:02 UTC (~24h ago)",
        "variant": "lead"
      }
    },
    "fact2": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "sm"
      },
      "children": [
        "label2",
        "value2"
      ]
    },
    "label2": {
      "type": "Text",
      "props": {
        "text": "Threshold exceeded:",
        "variant": "body"
      }
    },
    "value2": {
      "type": "Text",
      "props": {
        "text": "12h threshold (2× the 6h cadence)",
        "variant": "lead"
      }
    },
    "fact3": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "sm"
      },
      "children": [
        "label3",
        "value3"
      ]
    },
    "label3": {
      "type": "Text",
      "props": {
        "text": "Latest status:",
        "variant": "body"
      }
    },
    "value3": {
      "type": "Badge",
      "props": {
        "text": "20:00 run recovered",
        "variant": "secondary"
      }
    },
    "fact4": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "label4",
        "value4"
      ]
    },
    "label4": {
      "type": "Text",
      "props": {
        "text": "Observation:",
        "variant": "body"
      }
    },
    "value4": {
      "type": "Text",
      "props": {
        "text": "Scheduler ticks ran throughout the day without dispatching heartbeat",
        "variant": "muted"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "investigation": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "inv_heading",
        "inv_text"
      ]
    },
    "inv_heading": {
      "type": "Heading",
      "props": {
        "text": "Investigation needed",
        "level": "h4"
      }
    },
    "inv_text": {
      "type": "Text",
      "props": {
        "text": "Worth a look at the dispatch logic",
        "variant": "body"
      }
    }
  }
